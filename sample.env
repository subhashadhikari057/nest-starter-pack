# --- Redis Configuration ---
# These variables are used for the Redis ACL user and password and are referenced in docker-compose.yml
# The Redis default user is disabled; set a custom username instead.
# REDIS_USERNAME=bullhouse
# REDIS_PASSWORD=YourSecureRedisPassword123

# --- Mongo Configuration ---
# These variables are used for the mongo user and password and are referenced in docker-compose.yml
# The Redis default user is disabled; set a custom username instead.
# MONGO_DATABASE=bullhouse
# MONGO_USERNAME=bullhouse
# MONGO_PASSWORD=YourSecureRedisPassword123

# --- RustFS (Object Storage) Configuration (Optional) ---
# The Access Key is like the username
RUSTFS_ACCESS_KEY=YourRustFSAdmin

# The Secret Key is like the password
RUSTFS_SECRET_KEY=YourRustFSSecretKey456


# --- RustFS Host Volume Path ---
# Define the local directory where the data should be stored.
# This variable should be UNCOMMITTED to Git.
# RUSTFS_HOST_DATA_PATH=/home/ranjan/development/storage/rustFS/data

# --- Local HLS nginx container (root docker-compose.yml nginx service) ---
# These drive the env-templated infra/nginx/hls.conf.template at container start.
# Defaults in docker-compose.yml let the stack run without uncommenting these.
# See infra/nginx/README.md for staging/production value references.
# HLS_LISTEN_PORT=8080
# HLS_SERVER_NAME=_
# HLS_AUTH_UPSTREAM=http://host.docker.internal:5001
# HLS_S3_UPSTREAM=http://rustfs:9000
# HLS_S3_BUCKET=bullhouse-dev
# HLS_ALLOW_ORIGIN=*
# HLS_TLS_ENABLED=false
