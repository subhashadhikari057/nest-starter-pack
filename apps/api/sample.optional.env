########################################
# Optional/tuning env for target modules only
# Scope: training, promotion, podcast, order,
# course, content, catalog, cart, booklet
#
# How to use:
# - Keep a key unset to use defaults/fallbacks.
# - Set only keys you want to override.
# - Tune one block at a time and monitor impact.
########################################

########################################
# Notifications / Email Branding
#
# Tune when:
# - Brand identity, logo, support contact, or footer copy changes.
########################################

# Support email shown in transactional email footer.
# Default: support@bullhouse.com (service fallback).
SUPPORT_EMAIL=

# Brand display name in transactional email layout.
# Default: Bullhouse (service fallback).
EMAIL_BRAND_NAME=

# Public HTTPS logo URL for email header.
# Default: unset (text brand name is used).
EMAIL_BRAND_LOGO_URL=

# Footer copy at bottom of transactional emails.
# Default: generated message "You are receiving this transactional email from <brand>".
EMAIL_FOOTER_TEXT=

########################################
# Promotion
#
# Tune when:
# - Promotion endpoints return 429 in normal usage.
# - Cache freshness vs DB-load tradeoff changes.
########################################

# Max admin promotion operations per window.
# Default: 120 (env.validation).
PROMOTION_ADMIN_RATE_LIMIT=120

# Admin promotion rate-limit window in seconds.
# Default: 60 (env.validation).
PROMOTION_ADMIN_RATE_WINDOW_SECONDS=60

# Max customer promotion operations per window.
# Default: 60 (env.validation).
PROMOTION_CUSTOMER_OPERATION_RATE_LIMIT=60

# Customer promotion rate-limit window in seconds.
# Default: 60 (env.validation).
PROMOTION_CUSTOMER_RATE_WINDOW_SECONDS=60

# Admin promotion cache TTL in seconds.
# Default: 120 (env.validation).
PROMOTION_ADMIN_CACHE_TTL_SECONDS=120

# Customer promotion cache TTL in seconds.
# Default: 120 (env.validation).
PROMOTION_CUSTOMER_CACHE_TTL_SECONDS=120

########################################
# Booklet
#
# Tune when:
# - Booklet admin/customer endpoints are over/under throttled.
########################################

# Max booklet admin operations per window.
# Default: 100 (env.validation).
BOOKLET_ADMIN_RATE_LIMIT=100

# Booklet admin rate-limit window in seconds.
# Default: 60 (env.validation).
BOOKLET_ADMIN_RATE_WINDOW_SECONDS=60

# Max booklet customer operations per window.
# Default: 60 (env.validation).
BOOKLET_CUSTOMER_RATE_LIMIT=60

# Booklet customer rate-limit window in seconds.
# Default: 60 (env.validation).
BOOKLET_CUSTOMER_RATE_WINDOW_SECONDS=60

########################################
# Podcast / Queue Defaults
#
# Tune when:
# - Queue retries are too aggressive/weak.
# - Ack timeout is too short/long for infra latency.
########################################

# Ack timeout for realtime acknowledgment flow in milliseconds.
# Default: 10000 (env.validation).
ACK_TIMEOUT=10000

# Default BullMQ priority when job-specific priority is not set.
# Default: 0 (env.validation).
BULL_DEFAULT_PRIORITY=0

# Default BullMQ attempts when job-specific attempts are not set.
# Default: 4 (env.validation).
BULL_DEFAULT_ATTEMPTS=4

# Default BullMQ backoff delay in milliseconds.
# Default: 2000 (env.validation).
BULL_DEFAULT_BACKOFF_DELAY_MS=2000

# Default BullMQ completed-job retention age in seconds.
# Default: 7200 (env.validation).
BULL_DEFAULT_REMOVE_ON_COMPLETE_AGE_SEC=7200

# Default BullMQ completed-job retention count.
# Default: 5000 (env.validation).
BULL_DEFAULT_REMOVE_ON_COMPLETE_COUNT=5000

# Default BullMQ failed-job retention age in seconds.
# Default: 172800 (env.validation).
BULL_DEFAULT_REMOVE_ON_FAIL_AGE_SEC=172800

# Default BullMQ failed-job retention count.
# Default: 5000 (env.validation).
BULL_DEFAULT_REMOVE_ON_FAIL_COUNT=5000

########################################
# Order Customer/Admin APIs
#
# Tune when:
# - Customer/admin order endpoints hit 429 under valid load.
# - Auto-cancel window requires product/business adjustment.
########################################

# Minutes before pending unpaid orders auto-cancel.
# Default: 30 (env.validation).
ORDER_AUTO_CANCEL_MINUTES=30

# Checkout operation rate limit per window.
# Default: 10 (env.validation).
ORDER_CHECKOUT_RATE_LIMIT=10

# Retry-payment operation rate limit per window.
# Default: 5 (env.validation).
ORDER_RETRY_PAYMENT_RATE_LIMIT=5

# Cancel operation rate limit per window.
# Default: 10 (env.validation).
ORDER_CANCEL_RATE_LIMIT=10

# Refund-request operation rate limit per window.
# Default: 5 (env.validation).
ORDER_REFUND_REQUEST_RATE_LIMIT=5

# Customer order operation rate-limit window in seconds.
# Default: 60 (env.validation).
ORDER_CHECKOUT_RATE_WINDOW_SECONDS=60

# Customer order-history cache TTL in seconds.
# Default: 120 (env.validation).
ORDER_HISTORY_CACHE_TTL_SECONDS=120

# Admin order cache TTL in seconds.
# Default: 60 (env.validation).
ORDER_ADMIN_CACHE_TTL_SECONDS=60

# Admin order operation rate limit per window.
# Default: 120 (env.validation).
ORDER_ADMIN_OPERATION_RATE_LIMIT=120

# Admin order rate-limit window in seconds.
# Default: 60 (env.validation).
ORDER_ADMIN_RATE_WINDOW_SECONDS=60

########################################
# Outbox / Maintenance / Retry / Workers
#
# Tune when:
# - Outbox grows too quickly.
# - Retry storms occur.
# - Worker throughput/DB pressure requires balancing.
########################################

# Delivered outbox record retention in days.
# Default: 7 (env.validation).
OUTBOX_RETENTION_DAYS=7

# Failed outbox record retention in days.
# Default: 30 (env.validation).
OUTBOX_FAILED_RETENTION_DAYS=30

# Enables scheduled outbox cleanup.
# Default: true (env.validation).
OUTBOX_CLEANUP_ENABLED=true

# Outbox cleanup cron schedule.
# Default: "0 3 * * *" (env.validation).
# Note: interpreted in server timezone. Set server TZ to Asia/Kathmandu
# for strict Nepal-time execution.
OUTBOX_CLEANUP_CRON="0 3 * * *"

# Cleanup DLQ/failure warning threshold.
# Default: 100 (env.validation).
OUTBOX_CLEANUP_DLQ_THRESHOLD=100

# Max outbox records pulled per dispatch batch.
# Default: 300 (env.validation).
OUTBOX_BATCH_SIZE=300

# Retry base delay in milliseconds.
# Default: 2000 (env.validation).
RETRY_BASE_DELAY_MS=2000

# Retry max delay cap in milliseconds.
# Default: 120000 (env.validation).
RETRY_MAX_DELAY_MS=120000

# Payment retry max attempts used when enqueueing order payment retries.
# Default: 3 (env.validation).
ORDER_PAYMENT_RETRY_MAX_ATTEMPTS=3

# Payment retry delay for attempt 1 in milliseconds.
# Default: 60000 (env.validation).
PAYMENT_RETRY_DELAY_ATTEMPT_1_MS=60000

# Payment retry delay for attempt 2 in milliseconds.
# Default: 300000 (env.validation).
PAYMENT_RETRY_DELAY_ATTEMPT_2_MS=300000

# Payment retry delay for attempt 3+ in milliseconds.
# Default: 900000 (env.validation).
PAYMENT_RETRY_DELAY_ATTEMPT_3_MS=900000

# Failed-job warning threshold.
# Default: 50 (env.validation).
DLQ_WARNING_THRESHOLD=50

########################################
# Subscription warning extension
#
# Tune when:
# - Renewal popup timing changes.
# - Temporary extension days change.
########################################

# Enables the pre-expiry popup extension flow.
# Default: false (env.validation).
SUBSCRIPTION_WARNING_EXTENSION_ENABLED=false

# Popup eligibility threshold in days before expiry.
# Default: 1 (env.validation).
SUBSCRIPTION_WARNING_THRESHOLD_DAYS=1

# Temporary extension days granted after popup acceptance.
# Default: 1 (env.validation).
SUBSCRIPTION_WARNING_EXTENSION_DAYS=1

# Deliberate exception:
# QUEUE_FAILED_THRESHOLD_<QUEUE_NAME> keys are dynamic and not schema-listed.
# They are optional per-queue overrides read at runtime by scheduler.
# Example:
# QUEUE_FAILED_THRESHOLD_ORDERS=50
# QUEUE_FAILED_THRESHOLD_CART=50

# Cron for outbox dispatch scheduler.
# Default: "* * * * *" (env.validation).
ORDERS_DISPATCH_CRON="* * * * *"

# Cron for failed-queue monitoring scheduler.
# Default: "*/5 * * * *" (env.validation).
ORDERS_FAILED_MONITOR_CRON="*/5 * * * *"

# Preview sample size logged by outbox dispatcher.
# Default: 10 (env.validation).
OUTBOX_PENDING_PREVIEW_LIMIT=10

# Orders worker concurrency override.
# Default: 20 (env.validation).
WORKER_ORDERS_CONCURRENCY=20

# Orders maintenance worker concurrency override.
# Default: 8 (env.validation).
WORKER_ORDERS_MAINTENANCE_CONCURRENCY=8

########################################
# Catalog
#
# Tune when:
# - Search 429s increase.
# - Cache staleness/DB load needs balancing.
########################################

# Admin product-search rate limit per window.
# Default: 100 (env.validation).
CATALOG_ADMIN_PRODUCT_SEARCH_RATE_LIMIT=100

# Admin product-search window in seconds.
# Default: 60 (env.validation).
CATALOG_ADMIN_PRODUCT_SEARCH_RATE_WINDOW_SECONDS=60

# Customer product-search rate limit per window.
# Default: 50 (env.validation).
CATALOG_CUSTOMER_PRODUCT_SEARCH_RATE_LIMIT=50

# Customer product-search window in seconds.
# Default: 60 (env.validation).
CATALOG_CUSTOMER_PRODUCT_SEARCH_RATE_WINDOW_SECONDS=60

# Global catalog cache TTL fallback in seconds.
# Default: 7200 (env.validation).
CATALOG_CACHE_TTL_SECONDS=7200

# Category cache TTL in seconds.
# Default: 21600 (env.validation).
CATALOG_CATEGORY_CACHE_TTL_SECONDS=21600

# Tag cache TTL in seconds.
# Default: 21600 (env.validation).
CATALOG_TAG_CACHE_TTL_SECONDS=21600

# Featured cache TTL in seconds.
# Default: 1800 (env.validation).
CATALOG_FEATURED_CACHE_TTL_SECONDS=1800

# Default page size for /products/featured when size is omitted.
# Default: 10 (env.validation).
CATALOG_FEATURED_DEFAULT_SIZE=10

# Product cache TTL in seconds.
# Default: 7200 (env.validation).
CATALOG_PRODUCT_CACHE_TTL_SECONDS=7200

########################################
# Cart
#
# Tune when:
# - Cart endpoint 429s increase.
# - Cart cache freshness/load requirements change.
########################################

# Customer cart operation rate limit per window.
# Default: 60 (env.validation).
CART_CUSTOMER_OPERATION_RATE_LIMIT=60

# Customer cart rate-limit window in seconds.
# Default: 60 (env.validation).
CART_CUSTOMER_RATE_WINDOW_SECONDS=60

# Customer cart cache TTL in seconds.
# Default: 60 (env.validation).
CART_CUSTOMER_CACHE_TTL_SECONDS=60

########################################
# Content
#
# Tune when:
# - Content endpoints show frequent 429s.
# - Search/list throughput changes.
# - Content cache staleness/load requires adjustment.
########################################

# Customer item endpoint rate limit per window.
# Default: 30 (env.validation).
CONTENT_CUSTOMER_ITEM_RATE_LIMIT=30

# Customer item endpoint window in seconds.
# Default: 60 (env.validation).
CONTENT_CUSTOMER_ITEM_RATE_WINDOW_SECONDS=60

# Customer series list endpoint rate limit per window.
# Default: 100 (env.validation).
CONTENT_CUSTOMER_SERIES_RATE_LIMIT=100

# Customer series search endpoint rate limit per window.
# Default: 50 (env.validation).
CONTENT_CUSTOMER_SERIES_SEARCH_RATE_LIMIT=50

# Customer series window in seconds.
# Default: 60 (env.validation).
CONTENT_CUSTOMER_SERIES_RATE_WINDOW_SECONDS=60

# Admin content endpoint rate limit per window.
# Default: 100 (env.validation).
CONTENT_ADMIN_RATE_LIMIT=100

# Admin content endpoint window in seconds.
# Default: 60 (env.validation).
CONTENT_ADMIN_RATE_WINDOW_SECONDS=60

# Customer series cache TTL in seconds.
# Default: 1800 (env.validation).
CONTENT_CUSTOMER_SERIES_CACHE_TTL_SECONDS=1800

# Customer item cache TTL in seconds.
# Default: 900 (env.validation).
CONTENT_CUSTOMER_ITEM_CACHE_TTL_SECONDS=900

# Customer library cache TTL in seconds.
# Default: 60 (env.validation).
CONTENT_CUSTOMER_MY_LIBRARY_CACHE_TTL_SECONDS=60

# Customer purchases cache TTL in seconds.
# Default: 60 (env.validation).
CONTENT_CUSTOMER_PURCHASES_CACHE_TTL_SECONDS=60

# Fallback content cache TTL override in seconds.
# Default: unset (env.validation); service fallback applies.
CONTENT_CACHE_TTL_SECONDS=60

########################################
# Training
#
# Tune when:
# - Training admin endpoints are over/under throttled.
########################################

# Training admin operation rate limit per window.
# Default: 120 (env.validation).
TRAINING_ADMIN_RATE_LIMIT=120

# Training admin rate-limit window in seconds.
# Default: 60 (env.validation).
TRAINING_ADMIN_RATE_WINDOW_SECONDS=60

########################################
# Search / Ranking
#
# Tune when:
# - Search result strictness/recall needs adjustment.
########################################

# Trigram similarity threshold used across catalog/course/training/booklet/content/podcast search.
# Default: 0.3 (env.validation). Range: 0 to 1.
SEARCH_SIMILARITY_THRESHOLD=0.3

########################################
# Course Cache/Rate Overrides
#
# Tune when:
# - Course-specific cache policy should differ from shared defaults.
# - Certificate verification endpoint needs dedicated throttle values.
#
# Certificate verify keys can remain empty for fallback behavior.
########################################

# Customer quiz cache TTL override in seconds.
# Default: 300 (env.validation).
COURSE_CUSTOMER_QUIZ_CACHE_TTL_SECONDS=300

# Admin quiz cache TTL override in seconds.
# Default: 300 (env.validation).
COURSE_ADMIN_QUIZ_CACHE_TTL_SECONDS=300

# Admin certificate cache TTL override in seconds.
# Default: 300 (env.validation).
COURSE_ADMIN_CERTIFICATE_CACHE_TTL_SECONDS=300

# Certificate verification rate limit per window.
# Default: unset (env.validation); service fallback applies.
COURSE_CERTIFICATE_VERIFY_RATE_LIMIT=

# Certificate verification window in seconds.
# Default: unset (env.validation); service fallback applies.
COURSE_CERTIFICATE_VERIFY_RATE_WINDOW_SECONDS=

########################################
# Podcast
#
# Tune when:
# - YouTube oEmbed provider endpoint must be overridden.
########################################

# YouTube oEmbed endpoint for metadata fetch.
# Default: https://www.youtube.com/oembed (env.validation).
PODCAST_OEMBED_ENDPOINT=https://www.youtube.com/oembed
