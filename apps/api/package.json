{
	"name": "@bullhouse/api",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "MIT",
	"scripts": {
		"ensure:workspace-deps": "node ./scripts/ensure-workspace-deps-built.mjs",
		"generate:jwt-keys": "node ./scripts/generate-jwt-keys.mjs",
		"prebuild": "pnpm run ensure:workspace-deps",
		"build": "nest build --builder swc --path tsconfig.swc.json",
		"postbuild": "node ./scripts/ensure-build-entrypoint.mjs",
		"build:tsc": "nest build",
		"build:swc": "nest build --builder swc --path tsconfig.swc.json && node ./scripts/ensure-build-entrypoint.mjs",
		"check": "biome check --write .",
		"check-types": "tsc -b",
		"predev": "pnpm run ensure:workspace-deps",
		"dev": "nest start --builder swc --watch --path tsconfig.swc.json",
		"dev:dev": "nest start --watch",
		"predev:fast": "pnpm run ensure:workspace-deps",
		"dev:fast": "SWAGGER_ENABLED=false nest start --builder swc --watch --path tsconfig.swc.json",
		"predev:swc": "pnpm run ensure:workspace-deps",
		"dev:swc": "nest start --builder swc --watch --path tsconfig.swc.json",
		"start:debug": "nest start --debug --watch",
		"prestart": "pnpm run ensure:workspace-deps && node ./scripts/ensure-jwt-env.mjs",
		"start": "node dist/src/main.js",
		"prestart:staging": "pnpm run ensure:workspace-deps && node ./scripts/ensure-jwt-env.mjs",
		"start:staging": "node dist/src/main.js",
		"permissions:sync": "dotenv -e .env -- ts-node --project tsconfig.json scripts/sync-permissions.ts",
"verify:phase12:legacy-audit": "ts-node --project tsconfig.json scripts/training-video-legacy-audit.ts --enforce=false",
		"verify:phase12:legacy-gate": "ts-node --project tsconfig.json scripts/training-video-legacy-audit.ts --enforce=true",
		"migrate:phase12:training-video": "ts-node --project tsconfig.json scripts/training-video-migrate-legacy.ts",
		"migrate:phase12:training-video:dry-run": "ts-node --project tsconfig.json scripts/training-video-migrate-legacy.ts --dry-run",
		"dev:phase12:training-video-reseed": "ts-node --project tsconfig.json scripts/training-video-dev-reseed.ts",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:int": "jest --testRegex '.*\\.(integration|int)\\.spec\\.ts$'",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json"
	},
	"dependencies": {
		"@bull-board/api": "^6.16.4",
		"@bull-board/express": "^6.16.4",
		"@bull-board/nestjs": "^6.16.4",
		"@bullhouse/db": "workspace:*",
		"@bullhouse/email": "workspace:*",
		"@bullhouse/firebase": "workspace:*",
		"@bullhouse/jobs": "workspace:*",
		"@bullhouse/mongodb": "workspace:*",
		"@bullhouse/otp": "workspace:*",
		"@bullhouse/realtime-core": "workspace:*",
		"@bullhouse/redis": "workspace:*",
		"@bullhouse/storage": "workspace:*",
		"@nestjs/bullmq": "^11.0.4",
		"@nestjs/common": "^11.1.9",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.1.9",
		"@nestjs/event-emitter": "^3.0.1",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/mapped-types": "*",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.1.9",
		"@nestjs/platform-socket.io": "^11.1.9",
		"@nestjs/schedule": "^6.1.0",
		"@nestjs/serve-static": "^5.0.4",
		"@nestjs/swagger": "^11.2.3",
		"@nestjs/websockets": "^11.1.9",
		"@scalar/nestjs-api-reference": "^1.0.13",
		"@socket.io/redis-adapter": "^8.3.0",
		"bcrypt": "^5.1.1",
		"bullmq": "^5.66.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.3",
		"cron": "^4.3.5",
		"date-fns": "^4.1.0",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.44.7",
		"helmet": "^8.1.0",
		"libphonenumber-js": "^1.12.33",
		"multer": "^2.0.2",
		"passport": "^0.7.0",
		"passport-facebook": "^3.0.0",
		"passport-google-oauth20": "^2.0.0",
		"passport-jwt": "^4.0.1",
		"passport-local": "^1.0.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"sharp": "^0.34.5",
		"socket.io": "^4.8.1",
		"swagger-themes": "^1.4.3",
		"uuid": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.14",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.1.9",
		"@swc/cli": "^0.7.10",
		"@swc/core": "^1.15.11",
		"@types/bcrypt": "^5.0.2",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/multer": "^2.0.0",
		"@types/node": "catalog:",
		"@types/passport": "^1.0.16",
		"@types/passport-facebook": "^3.0.1",
		"@types/passport-google-oauth20": "^2.0.11",
		"@types/passport-local": "^1.0.38",
		"@types/supertest": "^6.0.3",
		"dotenv-cli": "^11.0.0",
		"jest": "^30.0.0",
		"nock": "^14.0.10",
		"socket.io-client": "^4.8.1",
		"supertest": "^7.0.0",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts",
			"tsx"
		],
		"rootDir": "src",
		"moduleNameMapper": {
			"^@/(.*)$": "<rootDir>/$1",
			"^uuid$": "<rootDir>/__mocks__/uuid.ts",
			"^@?/modules/notifications/transactional/email-templates/order-email$": "<rootDir>/modules/notifications/transactional/email-templates/__mocks__/order-email.ts",
			"^@?/modules/notifications/transactional/notification-router.service$": "<rootDir>/modules/notifications/transactional/__mocks__/notification-router.service.ts"
		},
		"testRegex": ".*\\.spec\\.ts$",
		"setupFiles": [
			"<rootDir>/../test/jest.setup-env.ts"
		],
		"transform": {
			"^.+\\.(t|j)sx?$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
