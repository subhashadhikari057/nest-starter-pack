{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "CommonJS",
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"composite": true,
		"outDir": "dist",
		"baseUrl": ".",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"incremental": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"strictNullChecks": false,
		"noImplicitAny": false,
		"strictBindCallApply": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"verbatimModuleSyntax": false,
		"jsx": "react-jsx",
		"types": ["node", "jest"],
		"paths": {
			"@bullhouse/api-types": ["../../packages/api-types/src/index.ts"],
			"@bullhouse/api-types/*": ["../../packages/api-types/src/*"],
			"@bullhouse/redis": ["../../packages/redis/dist/index.d.ts"],
			"@bullhouse/redis/*": ["../../packages/redis/dist/*"],
			"@bullhouse/firebase": ["../../packages/firebase/dist/index.d.ts"],
			"@bullhouse/firebase/*": ["../../packages/firebase/dist/*"],
			"@bullhouse/email": ["../../packages/email/dist/index.d.ts"],
			"@bullhouse/email/*": ["../../packages/email/dist/*"],
			"@bullhouse/otp": ["../../packages/otp/dist/index.d.ts"],
			"@bullhouse/otp/*": ["../../packages/otp/dist/*"],
			"@bullhouse/db": ["../../packages/db/dist/index.d.ts"],
			"@bullhouse/db/*": ["../../packages/db/dist/*"],
			"@bullhouse/mongodb": ["../../packages/mongodb/dist/index.d.ts"],
			"@bullhouse/mongodb/*": ["../../packages/mongodb/dist/*"],
			"@bullhouse/storage": ["../../packages/storage/dist/index.d.ts"],
			"@bullhouse/storage/*": ["../../packages/storage/dist/*"],
			"@bullhouse/jobs": ["../../packages/jobs/dist/index.d.ts"],
			"@bullhouse/jobs/*": ["../../packages/jobs/dist/*"],
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*", "test/**/*"],
	"exclude": ["node_modules", "dist"]
}
