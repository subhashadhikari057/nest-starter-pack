{
	"name": "@bullhouse/db",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js",
			"require": "./dist/*.js",
			"default": "./dist/*.js"
		}
	},
	"scripts": {
		"dev": "tsdown",
		"build": "tsdown",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:generate": "node src/scripts/generate.mjs",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "tsx src/seed/seed.ts",
		"db:seed:prod": "tsx src/seed/seed-prod.ts",
		"db:start": "docker compose up -d",
		"db:watch": "docker compose up",
		"db:stop": "docker compose stop",
		"db:down": "docker compose down",
		"db:verify-lineage": "tsx src/scripts/verify-migration-lineage.ts",
		"db:generate:named": "node src/scripts/generate-named.mjs"
	},
	"devDependencies": {
		"@types/bcrypt": "^5.0.2",
		"@types/pg": "^8.16.0",
		"drizzle-kit": "^0.31.8",
		"tsdown": "catalog:",
		"tsx": "^4.21.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@faker-js/faker": "^9.9.0",
		"bcrypt": "^5.1.1",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.44.7",
		"pg": "^8.14.1",
		"uuid": "catalog:",
		"zod": "catalog:"
	}
}
