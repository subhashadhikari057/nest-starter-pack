{
	"name": "@bullhouse/storage",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js",
			"require": "./dist/*.cjs",
			"default": "./dist/*.js"
		}
	},
	"scripts": {
		"build": "tsdown"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1023.0",
		"@aws-sdk/lib-storage": "^3.1023.0",
		"@aws-sdk/s3-request-presigner": "^3.1023.0",
		"@smithy/node-http-handler": "^4.5.1",
		"sharp": "^0.34.5",
		"zod": "catalog:"
	},
	"devDependencies": {
		"tsdown": "catalog:"
	},
	"peerDependencies": {
		"typescript": "catalog:"
	},
	"packageManager": "pnpm@10.10.0"
}
