{
	"name": "@bullhouse/email",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js",
			"require": "./dist/*.cjs",
			"default": "./dist/*.js"
		}
	},
	"scripts": {
		"build": "tsdown"
	},
	"dependencies": {
		"@react-email/render": "^2.0.0",
		"nodemailer": "^6.9.16",
		"react": "19.2.0",
		"react-dom": "19.2.0"
	},
	"devDependencies": {
		"@types/nodemailer": "^7.0.4",
		"@types/react": "~19.2.7",
		"tsdown": "catalog:"
	},
	"peerDependencies": {
		"typescript": "catalog:"
	},
	"packageManager": "pnpm@10.10.0"
}
